# Copy to .env and fill in values before running docker-compose

# JWT signing secret — use a strong random value in production
JWT_SECRET=change-me-to-a-strong-secret-at-least-32-chars

# WHIP stream key — used by Larix/OBS to authenticate WHIP publish requests
WHIP_STREAM_KEY=dev-stream-key-change-in-production

# STUN/TURN credentials for coturn
TURN_REALM=avoc.local
TURN_USER=avoc
TURN_PASSWORD=changeme

# Sprint 10: TURN network config
# On EC2: TURN_EXTERNAL_IP = Elastic IP, TURN_PRIVATE_IP = set automatically via IMDSv2 in deploy.sh
# Locally: set both to your LAN IP for local TURN testing
TURN_EXTERNAL_IP=127.0.0.1
# TURN_PRIVATE_IP is auto-fetched on EC2 (IMDSv2); set manually for local dev if needed
